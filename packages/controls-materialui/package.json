{
  "name": "@thx/controls-materialui",
  "version": "14.0.4",
  "description": "A collection of components designed with Material UI",
  "bugs": {
    "url": "https://github.com/thr-consulting/thr-addons/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thr-consulting/thr-addons.git"
  },
  "license": "MIT",
  "author": "Mike Kornelson <darkadept@durbn.net>",
  "main": "index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "index.js"
  ],
  "scripts": {
    "build": "yarn build:dev && yarn build:prod",
    "build:dev": "NODE_ENV=development webpack --config webpack.js",
    "build:prod": "NODE_ENV=production webpack --config webpack.js",
    "lint": "eslint --cache --ext js,ts src",
    "lint:fix": "eslint --cache --fix --ext js,ts src",
    "sort": "npx sort-package-json",
    "depcheck": "depcheck",
    "storybook": "start-storybook -p 8000 --ci",
    "ts": "tsc"
  },
  "eslintConfig": {
    "parserOptions": {
      "project": "./tsconfig-eslint.json"
    }
  },
  "dependencies": {
    "@date-io/date-fns": "^1.3.13",
    "@js-joda/core": "^3.0.0",
    "@thx/date": "^14.0.0",
    "@thx/money": "^14.0.0",
    "@thx/yup-types": "^14.0.0",
    "@types/inputmask": "^5.0.0",
    "debug": "^4.1.1",
    "eventemitter3": "^4.0.0",
    "flat": "^5.0.0",
    "formik": "^2.1.4",
    "inputmask": "^5.0.5",
    "js-money": "^0.6.3",
    "lodash": "^4.17.15",
    "react-table": "^7.6.3",
    "use-deep-compare-effect": "^1.3.1"
  },
  "devDependencies": {
    "css-loader": "^5.0.0",
    "style-loader": "^2.0.0"
  },
  "peerDependencies": {
    "@material-ui/core": "^4.x",
    "@material-ui/pickers": "^3.x",
    "react": "16.x || 17.x",
    "react-dom": "16.x || 17.x",
    "react-router-dom": "5.x"
  },
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public"
  }
}
