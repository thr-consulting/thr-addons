{
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": [
          "build",
          "deps",
          "lint",
          "lint.fix",
          "sort",
          "ts",
          "test"
        ]
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{projectRoot}/dist/esm",
        "{projectRoot}/dist/stats.html",
        "{projectRoot}/dist/stats.txt"
      ]
    },
    "sort": {
      "outputs": [
        "{projectRoot}/package.json"
      ]
    },
    "ts": {
      "outputs": [
        "{projectRoot}/dist/types"
      ]
    }
  }
}
